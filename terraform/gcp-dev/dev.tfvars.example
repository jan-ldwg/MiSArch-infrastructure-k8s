# Copy to dev.tfvars and adjust if needed:
#   cp dev.tfvars.example dev.tfvars
#
# Or let scripts/deploy-dev.sh pass project_id automatically from gcloud.

project_id   = "your-gcp-project-id"
region       = "europe-west3"
cluster_name = "misarch-cluster"

# Defaults to {project_id}-terraform-state when omitted.
# state_bucket_name = "your-gcp-project-id-terraform-state"
